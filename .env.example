# ─── Google Sheets ───
GOOGLE_SHEETS_CREDENTIALS=     # Base64-encoded service account JSON
GOOGLE_SHEET_ID=               # Spreadsheet ID from the URL

# ─── Gemini AI ───
GEMINI_API_KEY=                # Google AI Studio API key

# ─── LinkedIn ───
LINKEDIN_ACCESS_TOKEN=         # OAuth2 access token
LINKEDIN_PERSON_URN=           # e.g. urn:li:person:AbCdEf123

# ─── YouTube ───
YOUTUBE_CLIENT_SECRET=         # Base64-encoded OAuth client JSON
YOUTUBE_REFRESH_TOKEN=         # OAuth2 refresh token

# ─── Instagram ───
INSTAGRAM_ACCESS_TOKEN=        # Graph API long-lived token OR Buffer token
INSTAGRAM_ACCOUNT_ID=          # Instagram Business Account ID
INSTAGRAM_MODE=                # "graph" or "buffer" (default: graph)
BUFFER_PROFILE_ID=             # Required if INSTAGRAM_MODE=buffer

# ─── Failsafe Notifications ───
DISCORD_WEBHOOK_URL=           # Discord channel webhook
SLACK_WEBHOOK_URL=             # Slack incoming webhook (optional)
